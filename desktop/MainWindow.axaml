<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.openxmlformats.org/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="DesktopApp.MainWindow"
        Title="Posts Manager"
        Width="1400"
        Height="900"
        MinWidth="1100"
        MinHeight="760"
        Background="#F4EFE8">
  <Window.Styles>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#FFFDF9" />
      <Setter Property="BorderBrush" Value="#D8CEC0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="Foreground" Value="White" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*">
    <Border Background="#12263A" Padding="22,18">
      <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
        <StackPanel Spacing="4">
          <TextBlock Text="Posts Manager" FontSize="28" FontWeight="SemiBold" Foreground="#FFF8F0" />
          <TextBlock Text="Zero Nut desktop editor for posts.json" Foreground="#C5D0DB" FontSize="13" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <Button x:Name="ToggleFullscreenButton" Content="Toggle Fullscreen" Background="#2B8C7F" Click="ToggleFullscreen_Click" />
          <Button x:Name="SyncButton" Background="#D97706" Click="Sync_Click">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Sync to GitHub" />
              <ProgressBar x:Name="SyncProgress" Width="48" Height="4" IsIndeterminate="True" IsVisible="False" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Margin="20" Background="#FFFDF9" CornerRadius="24" BorderBrush="#E4DACC" BorderThickness="1">
      <Grid ColumnDefinitions="1.1*,10,0.95*">
        <Border Grid.Column="0" Padding="22,22,18,18" BorderBrush="#EEE4D7" BorderThickness="0,0,1,0">
          <Grid RowDefinitions="Auto,*,Auto" RowSpacing="14">
            <StackPanel Spacing="6">
              <TextBlock Text="Posts" FontSize="20" FontWeight="SemiBold" Foreground="#12263A" />
              <TextBlock Text="Recent entries from src/data/tg/posts.json." Foreground="#6B7280" FontSize="13" />
            </StackPanel>

            <Grid Grid.Row="1">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="PostsItemsControl">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,14" CornerRadius="18" BorderBrush="#E7DDD0" BorderThickness="1" Background="#FFFFFF" ClipToBounds="True">
                        <Grid Height="170">
                          <Image Source="{Binding BackgroundBitmap}" Opacity="0.12" Stretch="UniformToFill" />
                          <Border Background="#F7F2EA" Opacity="0.72" CornerRadius="18" />
                          <StackPanel Margin="18" Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                              <TextBlock Text="{Binding IdLabel}" FontWeight="SemiBold" Foreground="#12324D" />
                              <TextBlock Grid.Column="1" Text="{Binding DateText}" Foreground="#6B7280" FontSize="12" />
                            </Grid>
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="15" Foreground="#1F2937" />
                            <TextBlock Text="{Binding MusicDisplay}" Foreground="#1F7A4C" FontSize="12" IsVisible="{Binding HasMusic}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                              <Button Content="Edit" Background="#247B87" Tag="{Binding}" Click="EditPost_Click" />
                              <Button Content="Delete" Background="#B42318" Tag="{Binding}" Click="DeletePost_Click" />
                            </StackPanel>
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <Border x:Name="NoPostsMessage"
                      Background="#F5F0E8"
                      CornerRadius="18"
                      BorderBrush="#E7DDD0"
                      BorderThickness="1"
                      Padding="28"
                      IsVisible="False"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                  <TextBlock Text="No posts found" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="#24364A" />
                  <TextBlock Text="Add a new post with the form on the right." HorizontalAlignment="Center" Foreground="#6B7280" />
                </StackPanel>
              </Border>
            </Grid>

            <Border Grid.Row="2" Background="#F7F2EA" CornerRadius="14" Padding="12">
              <TextBlock x:Name="PostsFilePathText" Text="File path:" Foreground="#56616D" TextWrapping="Wrap" />
            </Border>
          </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="10" Background="Transparent" />

        <Border Grid.Column="2" Padding="22" Background="#FDF9F3" CornerRadius="0,24,24,0">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="18">
              <StackPanel Spacing="4">
                <TextBlock Text="Create post" FontSize="20" FontWeight="SemiBold" Foreground="#12263A" />
                <TextBlock Text="Add text, image and music metadata in one pass." Foreground="#6B7280" FontSize="13" />
              </StackPanel>

              <StackPanel Spacing="8">
                <TextBlock Text="Post text" FontWeight="SemiBold" />
                <TextBox x:Name="PostTextBox" AcceptsReturn="True" MinHeight="168" TextWrapping="Wrap" Watermark="Enter your post text here..." />
              </StackPanel>

              <StackPanel Spacing="8">
                <TextBlock Text="Date" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <DatePicker x:Name="PostDatePicker" Width="180" />
                  <TimePicker x:Name="PostTimePicker" Width="140" />
                </StackPanel>
              </StackPanel>

              <StackPanel Spacing="8">
                <TextBlock Text="Background image" FontWeight="SemiBold" />
                <Button Content="Choose Image" Background="#50657B" Click="SelectImage_Click" HorizontalAlignment="Left" />
                <Border Background="#FFFFFF" BorderBrush="#E7DDD0" BorderThickness="1" CornerRadius="12" Padding="12">
                  <StackPanel Spacing="10">
                    <TextBlock x:Name="SelectedImageNameText" Text="No image selected" Foreground="#56616D" />
                    <Image x:Name="SelectedImagePreview" Height="140" Stretch="UniformToFill" IsVisible="False" />
                    <Button x:Name="ClearImageButton" Content="Clear image" Background="#B42318" Click="ClearImage_Click" IsVisible="False" HorizontalAlignment="Left" />
                  </StackPanel>
                </Border>
              </StackPanel>

              <StackPanel Spacing="8">
                <TextBlock Text="Music" FontWeight="SemiBold" />
                <Button Content="Choose Music File" Background="#50657B" Click="SelectMusic_Click" HorizontalAlignment="Left" />
                <Border Background="#FFFFFF" BorderBrush="#E7DDD0" BorderThickness="1" CornerRadius="12" Padding="12">
                  <StackPanel Spacing="10">
                    <TextBlock x:Name="SelectedMusicNameText" Text="No music selected" Foreground="#56616D" />
                    <Button x:Name="ClearMusicButton" Content="Clear music" Background="#B42318" Click="ClearMusic_Click" IsVisible="False" HorizontalAlignment="Left" />
                    <Border x:Name="MusicMetadataPanel" Background="#F7F2EA" CornerRadius="10" Padding="10" IsVisible="False">
                      <StackPanel Spacing="8">
                        <StackPanel Spacing="6">
                          <TextBlock Text="Music title" FontWeight="SemiBold" />
                          <TextBox x:Name="MusicTitleTextBox" Watermark="Enter music title" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                          <TextBlock Text="Artist" FontWeight="SemiBold" />
                          <TextBox x:Name="MusicArtistTextBox" Watermark="Enter artist name" />
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </Border>
              </StackPanel>

              <Button Content="Add Post" Background="#2B8C7F" Click="AddPost_Click" Padding="16,12" />

              <Border x:Name="StatusBorder" Background="#E7F4EE" BorderBrush="#B9E3C8" BorderThickness="1" CornerRadius="12" Padding="12" IsVisible="False">
                <TextBlock x:Name="StatusText" Foreground="#155724" TextWrapping="Wrap" />
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <Border x:Name="EditOverlay" Grid.ColumnSpan="3" Background="#B312263A" IsVisible="False" ZIndex="10">
          <Border HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="820"
                  MaxHeight="840"
                  Background="#FFFDF9"
                  CornerRadius="24"
                  BorderBrush="#E4DACC"
                  BorderThickness="1"
                  Padding="22">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="16">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Edit post" FontSize="20" FontWeight="SemiBold" Foreground="#12263A" />
                    <TextBlock Text="Update content, date, image and music." Foreground="#6B7280" FontSize="13" />
                  </StackPanel>
                  <Button Content="×" Background="Transparent" Foreground="#56616D" Click="CloseEditDialog_Click" Padding="8,4" FontSize="24" />
                </Grid>

                <StackPanel Spacing="8">
                  <TextBlock Text="Post text" FontWeight="SemiBold" />
                  <TextBox x:Name="EditPostTextBox" AcceptsReturn="True" MinHeight="160" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Text="Date" FontWeight="SemiBold" />
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <DatePicker x:Name="EditDatePicker" Width="180" />
                    <TimePicker x:Name="EditTimePicker" Width="140" />
                  </StackPanel>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Text="Background image" FontWeight="SemiBold" />
                  <Button Content="Choose Image" Background="#50657B" Click="SelectEditImage_Click" HorizontalAlignment="Left" />
                  <Border Background="#FFFFFF" BorderBrush="#E7DDD0" BorderThickness="1" CornerRadius="12" Padding="12">
                    <StackPanel Spacing="10">
                      <TextBlock x:Name="EditSelectedImageNameText" Text="No image selected" Foreground="#56616D" />
                      <Image x:Name="EditSelectedImagePreview" Height="140" Stretch="UniformToFill" IsVisible="False" />
                      <Button x:Name="EditClearImageButton" Content="Clear image" Background="#B42318" Click="ClearEditImage_Click" IsVisible="False" HorizontalAlignment="Left" />
                    </StackPanel>
                  </Border>
                </StackPanel>

                <StackPanel Spacing="8">
                  <TextBlock Text="Music" FontWeight="SemiBold" />
                  <Button Content="Choose Music File" Background="#50657B" Click="SelectEditMusic_Click" HorizontalAlignment="Left" />
                  <Border Background="#FFFFFF" BorderBrush="#E7DDD0" BorderThickness="1" CornerRadius="12" Padding="12">
                    <StackPanel Spacing="10">
                      <TextBlock x:Name="EditSelectedMusicNameText" Text="No music selected" Foreground="#56616D" />
                      <Button x:Name="EditClearMusicButton" Content="Clear music" Background="#B42318" Click="ClearEditMusic_Click" IsVisible="False" HorizontalAlignment="Left" />
                      <Border x:Name="EditMusicMetadataPanel" Background="#F7F2EA" CornerRadius="10" Padding="10" IsVisible="False">
                        <StackPanel Spacing="8">
                          <StackPanel Spacing="6">
                            <TextBlock Text="Music title" FontWeight="SemiBold" />
                            <TextBox x:Name="EditMusicTitleTextBox" />
                          </StackPanel>
                          <StackPanel Spacing="6">
                            <TextBlock Text="Artist" FontWeight="SemiBold" />
                            <TextBox x:Name="EditMusicArtistTextBox" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                  <Button Content="Cancel" Background="#6B7280" Click="CloseEditDialog_Click" />
                  <Button Content="Save Changes" Background="#2B8C7F" Click="SaveEditedPost_Click" />
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Border>

        <Border x:Name="DeleteOverlay" Grid.ColumnSpan="3" Background="#B312263A" IsVisible="False" ZIndex="11">
          <Border HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="420"
                  Background="#FFFDF9"
                  CornerRadius="24"
                  BorderBrush="#E4DACC"
                  BorderThickness="1"
                  Padding="22">
            <StackPanel Spacing="16">
              <TextBlock Text="Delete post" FontSize="20" FontWeight="SemiBold" Foreground="#12263A" />
              <TextBlock x:Name="DeletePromptText" TextWrapping="Wrap" Foreground="#374151" />
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Cancel" Background="#6B7280" Click="CloseDeleteDialog_Click" />
                <Button Content="Delete" Background="#B42318" Click="ConfirmDelete_Click" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
